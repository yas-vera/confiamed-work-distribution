*.nupkg
*.snupkg
packages/
**/packages/*
!**/packages/build/

# Logs y temporales
*.log
*.tmp
*.temp

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Rider / JetBrains
.idea/

# Visual Studio Code
.vscode/
